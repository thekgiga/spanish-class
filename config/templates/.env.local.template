# ===========================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ===========================================
#
# This file is for local development only.
# Copy to: packages/backend/.env
#
# INSTRUCTIONS:
# 1. Copy this file: cp config/templates/.env.local.template packages/backend/.env
# 2. Update database credentials
# 3. Generate JWT secret: openssl rand -base64 32
#

# Environment
NODE_ENV=development
PORT=3001

# Database - Local MySQL/PostgreSQL
# Format: mysql://username:password@localhost:3306/database_name
DATABASE_URL="mysql://root:password@localhost:3306/spanish_class_dev"

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET="your-local-jwt-secret-min-32-characters"
JWT_EXPIRES_IN="7d"

# Application URLs
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3001/api"

# Email Service (Optional for local dev)
# RESEND_API_KEY="re_your_dev_api_key"
# EMAIL_FROM="Spanish Class Dev <noreply@localhost>"
# PROFESSOR_EMAIL="professor@localhost"

# Google Calendar API (Optional)
# GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key\n-----END PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID="primary"

# Jitsi Video Conferencing (Optional)
# JITSI_APP_ID=""
# JITSI_API_KEY=""

# Logging
LOG_LEVEL="debug"
