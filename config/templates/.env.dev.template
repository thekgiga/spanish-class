# ===========================================
# DEVELOPMENT SERVER ENVIRONMENT
# ===========================================
#
# This file is for dev.casovispanskog.rs deployment.
# Deploy to: ~/dev-casovispanskog-backend/.env
#
# INSTRUCTIONS:
# 1. Copy this file: cp config/templates/.env.dev.template config/dev/.env
# 2. Update ALL placeholder values (especially JWT_SECRET)
# 3. Deploy: ./scripts/deploy/deploy-dev.sh --with-config
#

# Environment
NODE_ENV=development
PORT=3001

# Database - Development Database on cPanel
# Format: mysql://[CPANEL_USER]_[DB_USER]:[PASSWORD]@localhost:3306/[CPANEL_USER]_[DB_NAME]
# IMPORTANT: Update with actual credentials
DATABASE_URL="mysql://gigovicr_dev_user:CHANGE_ME_PASSWORD@localhost:3306/gigovicr_spanish_dev"

# JWT Authentication
# CRITICAL: Generate unique secret with: openssl rand -base64 32
# NEVER use the same secret as production!
JWT_SECRET="CHANGE_ME_GENERATE_NEW_SECRET_MIN_32_CHARS"
JWT_EXPIRES_IN="7d"

# Application URLs
FRONTEND_URL="https://dev.casovispanskog.rs"
API_URL="https://dev.casovispanskog.rs/api"

# Email Service (Optional for dev testing)
# Get API key from: https://resend.com
# RESEND_API_KEY="re_dev_api_key_CHANGE_ME"
# EMAIL_FROM="Spanish Class Dev <noreply@dev.casovispanskog.rs>"
# PROFESSOR_EMAIL="professor@dev.casovispanskog.rs"

# Google Calendar API (Optional)
# GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key\n-----END PRIVATE KEY-----"
# GOOGLE_CALENDAR_ID="primary"

# Jitsi Video Conferencing (Optional)
# JITSI_APP_ID=""
# JITSI_API_KEY=""

# Logging
LOG_LEVEL="info"
